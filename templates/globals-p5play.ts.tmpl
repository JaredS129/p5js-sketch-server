// p5play requires p5 and planck to be available as window globals before it loads.
// This module must be imported before 'p5play' in any sketch that uses p5play.
import p5 from "p5";
// @ts-ignore - no types for planck bundled inside p5play
import planck from "p5play/planck.min.js";

(window as any).p5 = p5;
(window as any).planck = planck;

export {};
